# Hanoi Picks Message Operator
# Copy this file to .env on the machine that runs the bot.
# Never commit the real .env file.

DISCORD_BOT_TOKEN=
DISCORD_GUILD_ID=
MINIMAX_API_KEY=
MINIMAX_BASE_URL=https://api.minimax.io/v1
MINIMAX_MODEL=MiniMax-M3

# Where the owner commands the bot
CONTROL_CHANNEL_NAME=agent-control

# Target channels. Prefer IDs once the live server is connected.
ANNOUNCEMENTS_CHANNEL_NAME=announcements
MEMBER_ANNOUNCEMENTS_CHANNEL_NAME=member-announcements
JOIN_PREMIUM_CHANNEL_NAME=join-premium
FREE_PREMIUM_CHANNEL_NAME=free-premium
PREMIUM_WINS_CHANNEL_NAME=premium-wins
GIVEAWAYS_CHANNEL_NAME=giveaways
SOCIAL_MEDIA_CHANNEL_NAME=social-media
SUPPORT_CHANNEL_NAME=support

# Safety
REQUIRE_APPROVAL=true
DRY_RUN=true
